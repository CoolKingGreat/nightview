# Anthropic — agent LLM
ANTHROPIC_API_KEY=sk-ant-...

# Cesium Ion — Black Marble basemap tiles (free tier is fine)
# Get one at https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=eyJhbGciOi...

# Google Earth Engine — VIIRS DNB ingestion only (not needed for the live app)
# Path to a service-account JSON downloaded from the GCP console
GEE_SERVICE_ACCOUNT_JSON=./gee-service-account.json

# Backend
BACKEND_PORT=8000
TREND_PARQUET_PATH=./data/processed/trends.parquet

# Comma-separated list of allowed CORS origins for the API.
# Dev defaults are already wired in main.py; set this in production (Fly secret).
# ALLOWED_ORIGINS=https://nightview.aryanvalsa.me

# Frontend → backend. In dev, point at local FastAPI. In Vercel, set to
# https://api.nightview.aryanvalsa.me as a project env var (NOT committed here).
VITE_BACKEND_URL=http://localhost:8000
